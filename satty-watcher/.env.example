# Full path to the directory where your screenshots are saved
WATCH_DIR="/home/yourusername/Pictures/Screenshots"

# Full path to the Satty binary
SATTY_PATH="/home/yourusername/.local/bin/satty/satty"

# Where to store the cache of opened files
CACHE_FILE="/home/yourusername/.satty_cache.json"

# (Optional) file extension to watch
FILE_EXT=".png"
